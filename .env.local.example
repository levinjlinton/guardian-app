# ============================================================
# GUARDIAN — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# --- SUPABASE ---
# Get these from: https://app.supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# --- STRIPE ---
# Get these from: https://dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Your $3/month Price ID — created in Stripe dashboard
# Dashboard → Products → Create Product → Add Price → $3 recurring monthly
STRIPE_PRICE_ID=price_...

# Webhook secret — get from: Stripe Dashboard → Developers → Webhooks
# Add endpoint: https://yourdomain.com/api/stripe/webhook
# Events to listen for: checkout.session.completed, customer.subscription.updated, customer.subscription.deleted
STRIPE_WEBHOOK_SECRET=whsec_...

# --- APP ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
